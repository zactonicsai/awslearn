# terraform.tfvars.example
# ------------------------------------------------------------------
# Copy this to terraform.tfvars and fill in YOUR values.
#
#   cp terraform.tfvars.example terraform.tfvars
#
# terraform.tfvars is git-ignored. This .example file is not.
# NEVER put real values in the .example file.
# ------------------------------------------------------------------

aws_region   = "us-east-1"
project_name = "nifi-platform"
environment  = "dev"
owner        = "your-name"

# ---- FROM THE COMMAND NODE BUILD ----
# Get these by running scripts/00-bootstrap-command-node.sh, or:
#
#   TOKEN=$(curl -sX PUT "http://169.254.169.254/latest/api/token" \
#     -H "X-aws-ec2-metadata-token-ttl-seconds: 300")
#   IID=$(curl -s -H "X-aws-ec2-metadata-token: $TOKEN" \
#     http://169.254.169.254/latest/meta-data/instance-id)
#   aws ec2 describe-instances --instance-ids "$IID" \
#     --query 'Reservations[0].Instances[0].{SG:SecurityGroups[0].GroupId,VPC:VpcId}'
#
command_node_sg_id    = "sg-0REPLACE_ME"
command_node_vpc_id   = "vpc-0REPLACE_ME"
command_node_vpc_cidr = "172.31.0.0/16" # default VPC is usually this

# ---- YOUR DOMAIN ----
# Find the zone id with:
#   aws route53 list-hosted-zones --query "HostedZones[].{Name:Name,Id:Id}" --output table
domain_name     = "example.com"
nifi_subdomain  = "nifi"
route53_zone_id = "Z0REPLACE_ME"

# ---- WHO MAY REACH THE ALB ----
# Get yours with:  curl -s https://checkip.amazonaws.com
# The /32 means "exactly this one address, nothing else".
my_ip_cidr = "203.0.113.45/32"

# ---- SIZING (optional; these are the defaults) ----
# nifi_instance_type  = "t3.large"
# kafka_instance_type = "t3.medium"
# nifi_volume_size    = 100
# kafka_volume_size   = 100

# ==================================================================
# NOTE: There is NO ssh_key_name setting.
#
# This build uses AWS Systems Manager Session Manager exclusively.
# No EC2 key pair is created or referenced. No port 22 is opened on
# any security group. There is nothing to configure here.
# ==================================================================
