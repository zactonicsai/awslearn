# backend.tf is generated by scripts/bootstrap-state-s3.sh.
# Terraform backend settings cannot use normal Terraform variables.
# Copy this file to backend.tf only if you want to fill it in by hand.
terraform {
  backend "s3" {
    bucket       = "REPLACE_WITH_STATE_BUCKET"
    key          = "env/dev/aws-cloud-team-playbook.tfstate"
    region       = "us-east-1"
    encrypt      = true
    use_lockfile = true
  }
}
